[Desktop Entry]
Version=1.0
Type=Application
Name=AgentBaba
Comment=AI Browser Agent
Exec=bash -c 'rm -rf /tmp/chromium-profile && /usr/bin/python3 /home/baba/browser-agent/homie-extension/launch.py && /usr/bin/chromium --new-window --force-device-scale-factor=1 --load-extension=/home/baba/browser-agent/homie-extension --window-size=1200,600 --window-position=0,0 --user-data-dir=/tmp/chromium-profile --no-first-run --no-default-browser-check --disable-session-restore'
Icon=/home/baba/browser-agent/homie-extension/icons/icon128.png
Terminal=false
Categories=Network;
StartupNotify=true
StartupWMClass=chromium

