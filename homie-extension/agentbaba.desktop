[Desktop Entry]
Version=1.0
Type=Application
Name=AgentBaba
Comment=AI Browser Agent
Exec=bash -c 'read W H S <<< $(wlr-randr --json | jq -r ".[0] | \"\(.current_mode.width) \(.current_mode.height) \(.scale)\""); W=$((W/S)); H=$((H/S)); W=$((W*70/100)); H=$((H*60/100)); /usr/bin/python3 /home/baba/browser-agent/homie-extension/launch.py && /usr/bin/oranis --load-extension=/home/baba/browser-agent/homie-extension --window-size=${W},${H} --user-data-dir=/tmp/oranis-profile --no-first-run --no-default-browser-check --disable-session-restore'
Icon=/home/baba/browser-agent/homie-extension/icons/icon128.png
Terminal=false
Categories=Network;
StartupNotify=true
StartupWMClass=oranis